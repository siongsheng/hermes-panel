                    if rc == 0:
                        print(f"  Created: {stdout}", flush=True)
                    else:
                        print(f"  Failed: {stderr}", flush=True)
        else:
            print(f"\n── Phase 5: Tech Lead — SKIPPED (depth={depth}) ──", flush=True)
    else:
