            print(f"  Risk: {risk} (from strategist impact={impact})", flush=True)

            # Build nm output for report
            nm_output = (
                f"Tests: {tests_passed} passed, {tests_failed} failed\n"
                f"Build: {'PASS' if build_pass else 'FAIL'}\n"
