def load_key():
    env_path = os.path.join(PROFILES, "work", ".env")
    with open(env_path) as f:
        for line in f:
            if line.startswith("API_SERVER_KEY="):
                return line.strip().split("=", 1)[1]
    return ""

def load_github_token():
    env_path = os.path.join(PROFILES, "work", ".env")
    with open(env_path) as f:
        for line in f:
            if line.startswith("GH_TOKEN=") and not line.startswith("#"):
                return line.strip().split("=", 1)[1]
    return ""

def call_agent(port, system_prompt, user_prompt, model="deepseek-v4-pro", max_tokens=1500):
    payload = {"model": model, "messages": [
        {"role": "system", "content": system_prompt},
        {"role": "user", "content": user_prompt}
    ], "max_tokens": max_tokens}
    tmpfile = f"/tmp/hermes-panel-{port}.json"
    with open(tmpfile, "w") as f:
        json.dump(payload, f)
    auth = "Bearer" + " " + API_KEY
    cmd = ["curl", "-s", "--max-time", "180",
           f"http://127.0.0.1:{port}/v1/chat/completions",
           "-H", "Authorization:" + " " + auth,
           "-H", "Content-Type: application/json", "-d", f"@{tmpfile}"]
    result = subprocess.run(cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE, universal_newlines=True, timeout=190)
    if not result.stdout.strip():
        raise ValueError(f"Empty response from strategist API on port {port}")
    resp = json.loads(result.stdout)
    if "error" in resp:
        return {"error": resp["error"]["message"][:500]}
    return {"content": resp["choices"][0]["message"]["content"],
            "tokens": resp["usage"]["completion_tokens"]}

def spawn_agent(profile, skills, prompt, timeout=600, cwd=None):
    cmd = [HERMES_BIN, "--profile", profile, "--yolo"]
    for s in skills:
        cmd.extend(["-s", s])
    cmd.extend(["chat", "-q", prompt])
    tag = f"[{profile}]"
    print(f"\n{tag} ⏳ Spawning (timeout={timeout}s)...", flush=True)
    print(f"{tag} CMD: {' '.join(cmd[:4])} ...\n", flush=True)

    env = os.environ.copy()
    gh_token = load_github_token()
    if gh_token:
        env["GH_TOKEN"] = gh_token

    proc = subprocess.Popen(cmd, stdout=subprocess.PIPE, stderr=subprocess.STDOUT,
                            universal_newlines=True, cwd=cwd, env=env)
    output = []
    timed_out = False
    try:
        for line in proc.stdout:
            print(f"{tag} {line.rstrip()}", flush=True)
            output.append(line)
    except Exception:
        pass
    try:
        proc.wait(timeout=timeout)
    except subprocess.TimeoutExpired:
        timed_out = True
        print(f"\n{tag} ⚠ TIMEOUT after {timeout}s — killing process", flush=True)
        proc.kill()
        try:
            proc.wait(timeout=10)
        except subprocess.TimeoutExpired:
            proc.terminate()
        # Drain any remaining output after kill
        try:
            remaining = proc.stdout.read()
            if remaining:
                output.append(remaining)
        except Exception:
            pass

    result = "".join(output)
    if timed_out:
        result += f"\n\n[TIMEOUT: agent exceeded {timeout}s. Partial output above.]"
    return result

def git(*args, **kwargs):
    """Run git in PROJECT_DIR. Returns (stdout, stderr, returncode)."""
    result = subprocess.run(["git", "-C", PROJECT_DIR] + list(args),
                            stdout=subprocess.PIPE, stderr=subprocess.PIPE, universal_newlines=True, timeout=30)
    return result.stdout.strip(), result.stderr.strip(), result.returncode

def gh(*args, **kwargs):
    """Run gh CLI with GH_TOKEN. Returns (stdout, stderr, returncode)."""
    env = os.environ.copy()
    gh_token = load_github_token()
    if gh_token:
        env["GH_TOKEN"] = gh_token
    result = subprocess.run(["gh"] + list(args),
                            stdout=subprocess.PIPE, stderr=subprocess.PIPE, universal_newlines=True, timeout=30, env=env)
    return result.stdout.strip(), result.stderr.strip(), result.returncode

def slugify(text):
    return re.sub(r'[^a-z0-9-]', '', text.lower().replace(" ", "-"))[:40]

def extract_pr_sections(spec_text: str, feature: str) -> str:
    """Extract Why, Impact, and What Changed from the strategist's spec.
    Returns markdown sections: ## Why, ## Impact, ## What Changed."""

    # 1. ## Why — feature description + Position context
    why = f"## Why\n\n{feature}"
    pos_m = re.search(
        r'Position:\s*(.+?)(?=\n\s*\n\s*(?:\d\.\s*DECISION|DECISION|IMPACT|CONFIDENCE|### Task|Task \d|\Z))',
        spec_text, re.DOTALL | re.IGNORECASE
    )
    if pos_m:
        pos = pos_m.group(1).strip()
        pos = re.sub(r'\s+', ' ', pos)
        if len(pos) > 400:
            pos = pos[:397] + "..."
        why += f"\n\n{pos}"

    # 2. ## Impact — cascading effects, breaking changes, total lines
    impact_lines = []
    imp_m = re.search(
        r'IMPACT\s*ASSESSMENT\s*\n(.*?)(?=\n\s*\n\s*(?:CONFIDENCE|\d\.\s*CONFIDENCE|### Task|Task \d|\Z))',
        spec_text, re.DOTALL | re.IGNORECASE
    )
    if imp_m:
        imp = imp_m.group(1).strip()
        # Cascading effects (skip if "None" or empty)
        casc = re.search(r'Cascading effects?:?\s*\n(.+?)$', imp, re.DOTALL | re.IGNORECASE)
        if casc:
            casc_text = casc.group(1).strip()
            if casc_text.lower() not in ("none", "none."):
                impact_lines.append(casc_text)
        # Breaking changes
        breaking = re.search(r'Breaking\s*(?:change|changes?):?\s*(.+?)(?=\n\s*\n|\Z)', imp, re.DOTALL | re.IGNORECASE)
        if breaking:
            impact_lines.append(f"**Breaking:** {breaking.group(1).strip().replace(chr(10), ' ')}")
        # Total lines (handles both "Est. Lines:" and "Lines Est.:")
        total_lines = sum(int(n) for n in re.findall(r'(?:Est\.\s*Lines?|Lines\s*Est\.):?\s*[~+]?(\d+)', imp))
        if total_lines > 0:
            impact_lines.append(f"~{total_lines} lines changed across affected files")

    impact = f"## Impact\n\n" + "\n\n".join(impact_lines) if impact_lines else ""

    # 3. ## What Changed — area + file + change, formatted as clean bullets
    changed_lines = []
    if imp_m:
        imp = imp_m.group(1).strip()
        # Format A: Area: name, File(s): path, Change: desc
        items_a = re.findall(
            r'Area:\s*(.+?)\n\s*File\(s\):\s*(.+?)\n\s*Change:\s*(.+?)(?=\n\s*(?:Est\.|Risk|Area|──|\Z))',
            imp, re.DOTALL
        )
        if items_a:
            changed_lines.append("## What Changed")
            seen = set()
            for area, files, change in items_a:
                files_clean = files.strip()
                change_clean = change.strip().replace("\n", " ").strip()
                if len(change_clean) > 120:
                    change_clean = change_clean[:117] + "..."
                key = (area.strip(), files_clean)
                if key not in seen:
                    seen.add(key)
                    changed_lines.append(f"- **{area.strip()}:** {files_clean} — {change_clean}")
        else:
            # Format B: Area: filepath, Change: desc (area IS the file)
            items_b = re.findall(
                r'Area:\s*(.+?)\n\s*Change:\s*(.+?)(?=\n\s*(?:Lines Est\.|Risk|Area|──|\Z))',
                imp, re.DOTALL
            )
            if items_b:
                changed_lines.append("## What Changed")
                seen = set()
                for area, change in items_b:
                    area_clean = area.strip()
                    change_clean = change.strip().replace("\n", " ").strip()
                    if len(change_clean) > 120:
                        change_clean = change_clean[:117] + "..."
                    if area_clean not in seen:
                        seen.add(area_clean)
                        changed_lines.append(f"- **{area_clean}:** {change_clean}")

    what_changed = "\n".join(changed_lines) if len(changed_lines) > 1 else ""

    parts = [why]
    if impact:
        parts.append(impact)
    if what_changed:
        parts.append(what_changed)

    return "\n\n".join(parts)


def extract_agent_messages(session_output: str) -> str:
    """Extract agent messages from hermes session transcript, stripping noise
    (prompt echo, tool output, init markers). Keeps ALL agent reasoning."""
    # Hermes boxes: ╭─ ⚕ Hermes ──...──╮  ...content...  ╰──...──╯
    messages = re.findall(r'╭─ ⚕ Hermes .+?╮\n(.*?)╰─+╯', session_output, re.DOTALL)
    if messages:
        return "\n\n".join(m.strip() for m in messages if m.strip())
    # Fallback for unknown format: return raw output
    return session_output

def halt_and_revert(reason, phase, branch):
    """Revert all changes and print failure summary for orchestrator."""
    print(f"\n{'═'*55}", flush=True)
    print(f"  PIPELINE HALTED — {phase} Failed", flush=True)
    print(f"{'═'*55}", flush=True)
    print(f"\nReason: {reason}", flush=True)
    print("\nReverting all changes...", flush=True)
    git("checkout", DEFAULT_BRANCH)
    git("branch", "-D", branch)
    git("stash", "clear")
    print(f"  Branch '{branch}' deleted, back on master", flush=True)
    print("\n── Orchestrator Action Required ──", flush=True)
    print(f"  1. Review the failure context above", flush=True)
    print(f"  2. Diagnose root cause", flush=True)
    print(f"  3. Fix the issue (code, config, prompt, etc.)", flush=True)
    print(f"  4. Ask user for go-ahead before retrying", flush=True)
    print(f"\nFull log: {OUTPUT_LOG}", flush=True)

def detect_repo():
    """Extract owner/repo from git remote origin."""
    result = subprocess.run(["git", "-C", PROJECT_DIR, "remote", "get-url", "origin"],
                           stdout=subprocess.PIPE, stderr=subprocess.PIPE, universal_newlines=True, timeout=10)
    if result.returncode == 0:
        url = result.stdout.strip()
        m = re.search(r'github\.com[:/]([^/]+/[^/]+?)(?:\.git)?$', url)
        if m:
            return m.group(1)
    print("WARNING: Could not detect GitHub repo from git remote. Some gh commands may fail.")
    return None

def detect_commands():
    """Read test/build/lint commands from AGENTS.md in PROJECT_DIR."""
    test_cmd = "npm test"
    build_cmd = "npm run build"
    lint_cmd = "npm run lint"
    agents_path = os.path.join(PROJECT_DIR, "AGENTS.md")
    if os.path.exists(agents_path):
        with open(agents_path) as f:
            content = f.read()
            test_m = re.search(r'(?:[Uu]nit )?[Tt]est[s]?.*?:\s*`([^`]+)`', content)
            build_m = re.search(r'(?:[Ff]ull )?[Bb]uild.*?:\s*`([^`]+)`', content)
            lint_m = re.search(r'(?:[Ll]int).*?:\s*`([^`]+)`', content)
            if test_m:
                test_cmd = test_m.group(1)
            if build_m:
                build_cmd = build_m.group(1)
            if lint_m:
                lint_cmd = lint_m.group(1)
    return test_cmd, build_cmd, lint_cmd

