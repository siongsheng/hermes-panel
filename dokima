def _cleanup_lock():
    """Release lock and restore stdout on interrupt or normal exit."""
    global _LOCK_FD, _LOG_FILE, _STDOUT_ORIG, _LOG_FILE_HANDLE
    if _LOCK_FD:
        try:
            _LOCK_FD.close()
        except Exception:
