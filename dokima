            continue
        if arg == "--continuous":
            is_continuous = True
            is_next = True
            continue
        if arg == "--interactive":
            is_interactive = True
            continue
        if arg == "--stop":
            is_stop = True
            continue
        if arg == "--kill":
            is_kill = True
            continue
        if arg == "--status":
            is_status = True
            continue
        if arg == "--list-crons":
            is_list_crons = True
            continue
        if arg == "--answers":
            skip_next = True
            continue
        if arg == "--fix":
            is_fix = True
            continue
        filtered_argv.append(arg)

    answers_idx = None
    answers_path = None
    for i, arg in enumerate(sys.argv):
        if arg == "--answers" and i + 1 < len(sys.argv):
            answers_idx = i
            answers_path = sys.argv[i + 1]
            try:
                with open(answers_path) as f:
                    interview_state = json.load(f)
            except (FileNotFoundError, json.JSONDecodeError, IOError) as e:
