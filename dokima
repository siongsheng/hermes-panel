from utils import HELP_TEXT

def main():
    global API_KEY, PROJECT_DIR, REPO, TEST_CMD, BUILD_CMD, LINT_CMD, PANEL_FEATURE, DEFAULT_BRANCH, lock_fd, SKIP_AUTOFIX, FORCE_FULL, SKIP_HUMAN_GATE, max_parallel_override, FALLBACK_MODELS, RESUME
    import shutil
    import argparse as _ap

    # ── ARGPARSE PARSER ──────────────────────────────────
    parser = _ap.ArgumentParser(
        prog="dokima", add_help=False,
        description="Dokima — Multi-agent orchestration engine",
    )
    parser.add_argument("--help", "-h", action="store_true", default=False)
    parser.add_argument("--help-json", action="store_true", default=False)
    parser.add_argument("--map", action="store_true", default=False)
    parser.add_argument("--map-full", action="store_true", default=False)
    # Backward-compatible flags (also available as subcommands)
    parser.add_argument("--version", "-v", action="store_true", default=False)
    parser.add_argument("--upgrade", action="store_true", default=False)
    parser.add_argument("--list-crons", action="store_true", default=False)
    parser.add_argument("--next", action="store_true", default=False)
    parser.add_argument("--continuous", action="store_true", default=False)
    parser.add_argument("--fix", action="store_true", default=False)
    parser.add_argument("--fix-all", action="store_true", default=False)
    parser.add_argument("--add", action="store_true", default=False)
    parser.add_argument("--status", action="store_true", default=False)
    parser.add_argument("--stop", action="store_true", default=False)
    parser.add_argument("--kill", action="store_true", default=False)
    parser.add_argument("--release", action="store_true", default=False)
    parser.add_argument("--interactive", action="store_true", default=False)
    parser.add_argument("--skip-autofix", action="store_true", default=False)
    parser.add_argument("--force-full", action="store_true", default=False)
    parser.add_argument("--skip-auto-archive", action="store_true", default=False)
    parser.add_argument("--skip-human-gate", action="store_true", default=False)
    parser.add_argument("--resume", action="store_true", default=False)
    parser.add_argument("--no-resume", action="store_true", default=False)
    parser.add_argument("--max-parallel", type=int, default=None)
    parser.add_argument("--answers", type=str, default=None)
    parser.add_argument("--base-branch", type=str, default=None)
    parser.add_argument("--dry-run", action="store_true", default=False)
    parser.add_argument("--priority", type=str, default=None)

    sub = parser.add_subparsers(dest="command")

    # init subcommand
    p_init = sub.add_parser("init")
    p_init.add_argument("description", nargs="?", default="")
    p_init.add_argument("dir", nargs="?", default=None)

    # add subcommand
    p_add = sub.add_parser("add")
    p_add.add_argument("feature_desc", nargs="*", default=[])
    p_add.add_argument("--priority", default=None)
    p_add.add_argument("dir", nargs="?", default=None)

    # next subcommand
    p_next = sub.add_parser("next")
    p_next.add_argument("--continuous", action="store_true", default=False)
    p_next.add_argument("--force-full", action="store_true", default=False)
    p_next.add_argument("--interactive", action="store_true", default=False)
    p_next.add_argument("--skip-autofix", action="store_true", default=False)
    p_next.add_argument("--skip-auto-archive", action="store_true", default=False)
    p_next.add_argument("--skip-human-gate", action="store_true", default=False)
    p_next.add_argument("--resume", action="store_true", default=False)
    p_next.add_argument("--no-resume", action="store_true", default=False)
    p_next.add_argument("--max-parallel", type=int, default=None)
    p_next.add_argument("--answers", type=str, default=None)
    p_next.add_argument("--base-branch", type=str, default=None)
    p_next.add_argument("dir", nargs="?", default=None)
    p_next.add_argument("feature", nargs="?", default=None)

    # fix subcommand
    p_fix = sub.add_parser("fix")
    p_fix.add_argument("--fix-all", action="store_true", default=False)
    p_fix.add_argument("--skip-autofix", action="store_true", default=False)
    p_fix.add_argument("--skip-human-gate", action="store_true", default=False)
    p_fix.add_argument("--answers", type=str, default=None)
    p_fix.add_argument("dir", nargs="?", default=None)

    # status subcommand
    p_status = sub.add_parser("status")
    p_status.add_argument("dir", nargs="?", default=None)

    # stop subcommand
    p_stop = sub.add_parser("stop")
    p_stop.add_argument("dir", nargs="?", default=None)

    # kill subcommand
    p_kill = sub.add_parser("kill")
    p_kill.add_argument("dir", nargs="?", default=None)

    # list-crons subcommand
    p_list_crons = sub.add_parser("list-crons")

    # version subcommand
    p_version = sub.add_parser("version")

    # upgrade subcommand
    p_upgrade = sub.add_parser("upgrade")

    # release subcommand
    p_release = sub.add_parser("release")
    p_release.add_argument("bump", choices=["patch", "minor", "major"])
    p_release.add_argument("--dry-run", action="store_true", default=False)
    p_release.add_argument("dir", nargs="?", default=None)

    # ── Parse: catch unknown subcommand for default pipeline ──
    try:
        args = parser.parse_args()
        unknown = []
    except SystemExit as e:
        # argparse exits 2 on unknown subcommand; exit 0 for --help
        if e.code == 2 and len(sys.argv) > 1:
            if sys.argv[1] in ("--help", "-h", "--help-json", "--map", "--map-full",
                              "--version", "-v", "--upgrade", "--list-crons",
                              "--next", "--continuous", "--fix", "--fix-all",
                              "--add", "--status", "--stop", "--kill", "--release"):
                # Known flag with extra positionals — re-parse ignoring extras
                flag_parser = _ap.ArgumentParser(add_help=False, prog="dokima")
                flag_parser.add_argument("--help", "-h", action="store_true", default=False)
                flag_parser.add_argument("--help-json", action="store_true", default=False)
                flag_parser.add_argument("--map", action="store_true", default=False)
                flag_parser.add_argument("--map-full", action="store_true", default=False)
                flag_parser.add_argument("--version", "-v", action="store_true", default=False)
                flag_parser.add_argument("--upgrade", action="store_true", default=False)
                flag_parser.add_argument("--list-crons", action="store_true", default=False)
                flag_parser.add_argument("--next", action="store_true", default=False)
                flag_parser.add_argument("--continuous", action="store_true", default=False)
                flag_parser.add_argument("--fix", action="store_true", default=False)
                flag_parser.add_argument("--fix-all", action="store_true", default=False)
                flag_parser.add_argument("--add", action="store_true", default=False)
                flag_parser.add_argument("--status", action="store_true", default=False)
                flag_parser.add_argument("--stop", action="store_true", default=False)
                flag_parser.add_argument("--kill", action="store_true", default=False)
                flag_parser.add_argument("--release", action="store_true", default=False)
                args, unknown = flag_parser.parse_known_args()
                args.command = None
            elif not sys.argv[1].startswith("-"):
                # Unknown subcommand — treat as default pipeline positional args
                pipeline_p = _ap.ArgumentParser(add_help=False, prog="dokima")
                pipeline_p.add_argument("--help", "-h", action="store_true", default=False)
                pipeline_p.add_argument("--help-json", action="store_true", default=False)
                pipeline_p.add_argument("--map", action="store_true", default=False)
                pipeline_p.add_argument("--map-full", action="store_true", default=False)
                pipeline_p.add_argument("feature", nargs="?", default="")
                pipeline_p.add_argument("dir", nargs="?", default=None)
                pipeline_p.add_argument("--answers", type=str, default=None)
                pipeline_p.add_argument("--base-branch", type=str, default=None)
                args = pipeline_p.parse_args(sys.argv[1:])
                args.command = None  # mark as default pipeline
                args.continuous = False
                args.interactive = False
                args.force_full = False
                args.skip_autofix = False
                args.skip_auto_archive = False
                args.skip_human_gate = False
                args.resume = False
                args.no_resume = False
                args.max_parallel = None
                args.fix_all = False
                args.dry_run = False
                unknown = []
            else:
                raise
        else:
            raise

    # Flatten: if no args at all (no subcommand, no flags)
    if len(sys.argv) < 2:
        parser.print_usage()
        sys.exit(1)

    # ── Env var fallbacks for flags (flag wins if set, then env var, then default) ──
    fix_all = getattr(args, 'fix_all', False)
    if not fix_all and os.environ.get("PANEL_FIX_ALL") == "1":
        fix_all = True
    skip_autofix = getattr(args, 'skip_autofix', False)
    if not skip_autofix and os.environ.get("PANEL_SKIP_AUTOFIX") == "1":
        skip_autofix = True
        SKIP_AUTOFIX = True
    force_full = getattr(args, 'force_full', False)
    if not force_full and os.environ.get("PANEL_FORCE_FULL") == "1":
        force_full = True
        FORCE_FULL = True
    skip_auto_archive = getattr(args, 'skip_auto_archive', False)
    if not skip_auto_archive and os.environ.get("PANEL_SKIP_AUTO_ARCHIVE") == "1":
        skip_auto_archive = True
    skip_human_gate = getattr(args, 'skip_human_gate', False)
    if not skip_human_gate and os.environ.get("PANEL_SKIP_HUMAN_GATE") == "1":
        skip_human_gate = True
        SKIP_HUMAN_GATE = True
    max_parallel_override = getattr(args, 'max_parallel', None)
    if max_parallel_override is None:
        mp = os.environ.get("PANEL_MAX_PARALLEL")
        if mp and mp.isdigit():
            max_parallel_override = int(mp)
    # resume/no-resume
    if RESUME is None:
        if getattr(args, 'resume', False):
            RESUME = True
        elif getattr(args, 'no_resume', False):
            RESUME = False
        elif os.environ.get("PANEL_RESUME") == "1":
            RESUME = True
        elif os.environ.get("PANEL_NO_RESUME") == "1":
            RESUME = False

    # ── --base-branch flag ──
    base_branch_override = os.environ.get("PANEL_BASE_BRANCH") or None
    if getattr(args, 'base_branch', None):
        base_branch_override = args.base_branch

    # ── --answers flag ──
    user_answers_prefill = None
    answers_path = getattr(args, 'answers', None)
    if answers_path:
        try:
            with open(answers_path) as f:
                interview_state = json.load(f)
        except (FileNotFoundError, json.JSONDecodeError, IOError) as err:
            print(f"  ⚠ Failed to load answers file '{answers_path}': {err}", flush=True)
            answers_path = None
        else:
            answers_list = interview_state.get("answers", [])
            questions = interview_state.get("questions", [])
            if answers_list and questions:
                user_answers_prefill = "\n".join(
                    f"Clarification: {q}\nUser's answer: {a}"
                    for q, a in zip(questions, answers_list)
                )
                print(f"  ✓ Loaded {len(answers_list)} answer(s) from {answers_path}", flush=True)

    cmd = getattr(args, 'command', None)

    # ── Backward compatibility: old --flag syntax maps to subcommands ──
    if cmd is None:
        if getattr(args, 'next', False):
            cmd = "next"
        elif getattr(args, 'continuous', False):
            cmd = "next"
            args.continuous = True
        elif getattr(args, 'fix', False):
            cmd = "fix"
        elif getattr(args, 'add', False):
            cmd = "add"
        elif getattr(args, 'status', False):
            cmd = "status"
        elif getattr(args, 'stop', False):
            cmd = "stop"
        elif getattr(args, 'kill', False):
            cmd = "kill"
        elif getattr(args, 'release', False):
            cmd = "release"
            args.bump = None  # will be set from positional args

    # ── Extract dir from unknown args for backward-compat flags ──
    if unknown and not getattr(args, 'dir', None):
        for u in unknown:
            if not u.startswith('-'):
                args.dir = u
                break

    feature = ""

    # ── CONTROL FLAGS: early exit (before project setup, priority order) ──
    if getattr(args, 'help_json', False):
        show_help_json()
    if getattr(args, 'help', False):
        show_help()
    if cmd == "version" or getattr(args, 'version', False):
        print(f"dokima v{VERSION}")
        sys.exit(0)
    if cmd == "upgrade" or getattr(args, 'upgrade', False):
        check_upgrade()
    if cmd == "list-crons" or getattr(args, 'list_crons', False):
        handle_list_crons()
    if cmd == "kill":
        PROJECT_DIR = os.path.abspath(args.dir) if getattr(args, 'dir', None) else os.getcwd()
        handle_kill(PROJECT_DIR)

    # ── Extract feature for add command ──
    add_feature = ""
    if cmd == "add":
        fd = getattr(args, 'feature_desc', [])
        add_feature = " ".join(fd) if fd else ""
        if not add_feature:
            print("ERROR: add requires a feature description.")
            print("Usage: dokima add 'Feature description' [--priority=P0] [dir]")
            sys.exit(1)
        PROJECT_DIR = os.path.abspath(args.dir) if getattr(args, 'dir', None) else os.getcwd()
        add_priority = getattr(args, 'priority', None)
        if add_priority:
            add_priority = add_priority.upper()
            if add_priority not in ("P0", "P1", "P2", "P3"):
                print(f"  ⚠ Invalid --priority value: {add_priority} (use P0, P1, P2, or P3)", flush=True)
                add_priority = None
        run_add_to_roadmap(add_feature, PROJECT_DIR, priority_hint=add_priority)
        print("\n  Roadmap updated. Run 'dokima next' to build the next feature.")
        sys.exit(0)

    # ── Extract release bump ──
    release_bump = None
    if cmd == "release":
        release_bump = getattr(args, 'bump', None)
        if release_bump is None:
            print("ERROR: release requires a bump type (patch, minor, or major)", flush=True)
            print("Usage: dokima release <patch|minor|major> [--dry-run] [dir]", flush=True)
            sys.exit(1)
        PROJECT_DIR = os.path.abspath(args.dir) if getattr(args, 'dir', None) else os.getcwd()
        is_dry_run = getattr(args, 'dry_run', False)
        do_release(release_bump, PROJECT_DIR, dry_run=is_dry_run)
        return

    if cmd == "stop":
        PROJECT_DIR = os.path.abspath(args.dir) if getattr(args, 'dir', None) else os.getcwd()
        handle_stop(PROJECT_DIR)
    if cmd == "status":
        PROJECT_DIR = os.path.abspath(args.dir) if getattr(args, 'dir', None) else os.getcwd()
        handle_status(PROJECT_DIR)
    if getattr(args, 'map', False):
        PROJECT_DIR = os.path.abspath(args.dir) if getattr(args, 'dir', None) else os.getcwd()
        map_full_flag = getattr(args, 'map_full', False)
        generate_codebase_map(PROJECT_DIR, full=map_full_flag)
        return

    # ── Determine PROJECT_DIR for pipeline commands ──
    if cmd == "init":
        init_desc = getattr(args, 'description', '') or ""
        PROJECT_DIR = os.path.abspath(args.dir) if getattr(args, 'dir', None) else os.getcwd()
        feature = "init"
        PANEL_FEATURE = init_desc
    elif cmd == "fix":
        PROJECT_DIR = os.path.abspath(args.dir) if getattr(args, 'dir', None) else os.getcwd()
        PANEL_FEATURE = f"fix: {PROJECT_DIR}"
    elif cmd == "next":
        PROJECT_DIR = os.path.abspath(args.dir) if getattr(args, 'dir', None) else os.getcwd()
        feature = getattr(args, 'feature', '') or ""
        PANEL_FEATURE = feature
    elif cmd is None:
        # Default pipeline: positional args are feature + dir
        feature = getattr(args, 'feature', '') or ""
        if not feature:
            print("ERROR: Feature description required")
            sys.exit(1)
        PANEL_FEATURE = feature
        PROJECT_DIR = os.path.abspath(args.dir) if getattr(args, 'dir', None) else os.getcwd()
    else:
        PROJECT_DIR = os.getcwd()

    # ── INIT MODE: discovery & constitution, no pipeline ──
    if cmd == "init":
        run_init(init_desc, PROJECT_DIR)
        return

    # ── LOCK ACQUISITION ──
    _, lock_fd = acquire_lock()
    global _LOCK_FD
    _LOCK_FD = lock_fd
    signal.signal(signal.SIGINT, _signal_handler)
    signal.signal(signal.SIGTERM, _signal_handler)
    import atexit
    atexit.register(_cleanup_lock)
    # ── PROJECT SETUP ──
    # Validate PROJECT_DIR is a real git repo before proceeding
    if not _validate_project_dir(PROJECT_DIR):
        print(f"ERROR: {PROJECT_DIR} is not a valid git repository (no .git directory found).")
        print("  The panel requires a git repository to operate in.")
        print("  Use a project directory that has been initialized with 'git init' or cloned from GitHub.")
        _cleanup_lock()
        sys.exit(1)

    agents_path = os.path.join(PROJECT_DIR, "AGENTS.md")
    if not os.path.exists(agents_path):
        print(f"ERROR: No AGENTS.md found in {PROJECT_DIR}")
        print("  The panel requires an AGENTS.md at the project root with at minimum:")
        print("  project description, test command, build command, and conventions.")
        print("  See ai-coding-best-practices for AGENTS.md guidelines.")
        _cleanup_lock()
        sys.exit(1)

    API_KEY = load_key()
    if not API_KEY:
        print("ERROR: Could not read API_SERVER_KEY from .env")
        _cleanup_lock()
        sys.exit(1)

    # ── Load fallback model config ──
    FALLBACK_MODELS = _load_fallback_config()
    if FALLBACK_MODELS:
        roles = ", ".join(FALLBACK_MODELS.keys())
        print(f"  ✓ Fallback models configured for: {roles}", flush=True)

    REPO = detect_repo()
    if not REPO:
        print("ERROR: Could not detect GitHub owner/repo from git remote origin.")
        print("  The panel needs a GitHub remote to create PRs and issues.")
        _cleanup_lock()
        sys.exit(1)

    DEFAULT_BRANCH = _detect_default_branch(PROJECT_DIR)
    if base_branch_override:
        DEFAULT_BRANCH = base_branch_override
        print(f"  ⚡ Base branch override: {DEFAULT_BRANCH}", flush=True)
    _set_gh_token()
    TEST_CMD, BUILD_CMD, LINT_CMD = detect_commands()

    # ── --answers interaction for fix ──
    if cmd == "fix" and answers_path is not None:
        print("  ⚠ fix mode ignores --answers (no strategist interview). Continuing...", flush=True)

    # ── FIX MODE: early dispatch ──
    if cmd == "fix":
        # Use _pipeline reference so test patches on pipeline module take effect
        _pipeline.run_fix_mode(project_dir=PROJECT_DIR, fix_all=fix_all, skip_human_gate=skip_human_gate)
        _cleanup_lock()
        return

    # ── Auto-archive specs from merged PRs (fallback startup scan) ──
    specs_dir = os.path.join(PROJECT_DIR, "specs")
    archive_dir = os.path.join(specs_dir, "archive")
    if os.path.isdir(specs_dir) and not skip_auto_archive:
        merged_archived = 0
        for entry in sorted(os.listdir(specs_dir)):
            entry_path = os.path.join(specs_dir, entry)
            if not os.path.isdir(entry_path) or entry == "archive":
                continue
            # Use case-insensitive branch matching: lowercased entry matches slugify'd branch
            branch_name = f"feat/{entry.lower()}"[:80]
            try:
                result = subprocess.run(
                    ["gh", "pr", "list", "--repo", REPO, "--head", branch_name,
                     "--state", "merged", "--json", "number", "--jq", ".[0].number"],
                    capture_output=True, text=True, timeout=15)
                if result.returncode == 0 and result.stdout.strip():
                    os.makedirs(archive_dir, exist_ok=True)
                    archive_path = os.path.join(archive_dir, entry)
                    if os.path.exists(archive_path):
                        shutil.rmtree(archive_path)
                    shutil.move(entry_path, archive_path)
                    merged_archived += 1
            except Exception:
                pass
        if merged_archived:
            print(f"  Auto-archive: {merged_archived} merged spec(s) → specs/archive/")

    # ── NEXT MODE: pick feature from roadmap ──
    is_next = (cmd == "next")
    if is_next:
        git("checkout", DEFAULT_BRANCH)
        git("pull", "origin", DEFAULT_BRANCH)
        feature_hint = getattr(args, 'feature', None) or None
        is_interactive = getattr(args, 'interactive', False)
        feature = run_next_setup(interactive=is_interactive, feature_hint=feature_hint)
        if feature is None:
            print("Nothing to do.")
            _cleanup_lock()
            return
        PANEL_FEATURE = feature

    # ── Pre-pipeline stop file check ──
    sp = _stop_path(PROJECT_DIR)
    if os.path.exists(sp):
        print("  ⚠ Stop file detected — halting before pipeline")
        os.remove(sp)
        _cleanup_lock()
        return

    # ── Sync module globals before pipeline execution (F022b) ──
    _sync_modules()

    # ── RUN PIPELINE ──
    is_continuous = getattr(args, 'continuous', False)
    if is_continuous:
        roadmap_path = os.path.join(PROJECT_DIR, "specs", "roadmap.md")
        for iteration in range(1, MAX_CONTINUOUS + 1):
            print(f"\n{'═'*60}")
            print(f"  CONTINUOUS — Feature {iteration}")
            print(f"{'═'*60}\n")

            run_pipeline(feature, is_next, True, user_answers_prefill, resume=RESUME)

            # Check stop file
            if os.path.exists(_stop_path()):
                print("\n  ⚠ Stop file detected — halting continuous loop")
                os.remove(_stop_path())
                break

            if iteration >= MAX_CONTINUOUS:
                print(f"\n── Continuous: max iterations ({MAX_CONTINUOUS}) reached")
                break

            # Pick next feature
            if not os.path.exists(roadmap_path):
                break
            features = parse_roadmap(roadmap_path)
            auto_repair_status(features, roadmap_path)
            features = parse_roadmap(roadmap_path)
            next_feat = pick_next_feature(features)
            if not next_feat:
                print("\n── Continuous: all features complete")
                break
            feature = f"{next_feat.id}: {next_feat.title}"
            PANEL_FEATURE = feature
            update_roadmap_status(roadmap_path, next_feat.id, "in_progress")
            commit_roadmap_update(roadmap_path, next_feat.id, "start")
            status_path_c = os.path.join(PROJECT_DIR, "specs", "STATUS.md")
            branch_c = f"feat/{slugify(feature)[:50]}"
            update_status_md(status_path_c, next_feat.id, next_feat.title, "in_progress", branch=branch_c, source="panel")
            print(f"\n  Next: {next_feat.id} — {next_feat.title}")
    else:
        run_pipeline(feature, is_next, False, user_answers_prefill, resume=RESUME)

    _sync_modules()
    _cleanup_lock()

def _sync_modules():
    """Propagate mutable globals to all module files (F022)."""
    try:
        for g in ('PROJECT_DIR', 'REPO', 'DEFAULT_BRANCH', 'PANEL_FEATURE',
                  'PANEL_DIR', 'API_KEY', 'OUTPUT_LOG', 'HERMES_BIN',
                  'FALLBACK_MODELS', 'SKIP_AUTOFIX', 'FORCE_FULL',
                  'SKIP_HUMAN_GATE', 'max_parallel_override', 'RESUME',
                  'TEST_CMD', 'BUILD_CMD', 'LINT_CMD'):
            val = globals().get(g)
            if val is not None:
                for mod in (_utils, _agent, _tasks, _roadmap, _pipeline):
                    if hasattr(mod, g):
                        setattr(mod, g, val)
    except Exception:
        pass

if __name__ == "__main__":
    main()
