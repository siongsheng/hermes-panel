            stdout, stderr, rc = gh("issue", "create", "--repo", REPO,
                                    "--title", title, "--body", body)
            if rc == 0:
                print(f"  Created: {stdout}", flush=True)
            else:
                print(f"  Failed: {stderr}", flush=True)

    return {"verdict": verdict, "tl_output": tl_output}


