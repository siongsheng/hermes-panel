        ("tech-lead", "adversarial-review-lite", False),
        ("tech-lead", "ponytail-guard", False),
        ("nm", "no-mistakes", True),
    ]

    for profile, skill, is_global in _SKILL_MAPPINGS:
        src = os.path.join(skills_dir, skill)

