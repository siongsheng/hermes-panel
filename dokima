SKIP_AUTOFIX = False       # set from --skip-autofix flag or PANEL_SKIP_AUTOFIX env
FORCE_FULL = False         # set from --force-full flag or PANEL_FORCE_FULL env
SKIP_HUMAN_GATE = False    # set from --skip-human-gate flag or PANEL_SKIP_HUMAN_GATE env
max_parallel_override = None  # set from --max-parallel=N flag in main()
FALLBACK_MODELS = {}           # populated from PANEL_FALLBACK_* env vars in main()
RESUME = None                  # set from --resume/--no-resume flag or PANEL_RESUME env
