    # ── FLAG SCANNING ──
    is_next = False
    is_continuous = False
    is_interactive = False
    is_help = False
    is_stop = False
    is_kill = False
    is_status = False
    is_list_crons = False
    is_fix = False
    feature = ""
    user_answers_prefill = None
    filtered_argv = []
    skip_next = False
