#!/home/opc/.hermes/hermes-agent/venv/bin/python3
"""Dokima — Multi-agent orchestration engine.
Usage: dokima "Feature description" [project_dir]
       If project_dir is omitted, uses current working directory.
Flow: Strategist → User Clarifications → Strategist Refine → TL Spec Pre-Review → Orchestrator Gate → Human Gate → Coder(branch) → vet(validate) → nm(adversarial+PR) → Tech Lead(spec review) → Report
Output: Live to terminal + saved to /tmp/dokima-output.txt
"""

import sys, json, subprocess, os, pwd, time, shlex, re, fcntl, signal, datetime

# ── F022 Modular Architecture ───────────────────
# Module imports for state propagation (mutable globals flow FROM dokima TO modules).
import utils as _utils
import agent as _agent
import tasks as _tasks
import roadmap as _roadmap
import pipeline as _pipeline

# Import functions and classes only (NOT mutable globals — those stay in dokima).
from utils import (slugify, git, gh, _safe_run, _sanitize_prompt, _validate_project_dir,
                   _redact_secrets, _write_log_line, load_key, load_github_token,
                   extract_pr_sections, extract_agent_messages, clean_spec_content,
                   verify_spec_quality, _check_pr_body_quality, detect_repo, detect_commands,
                   _detect_referenced_repo, _lock_path, _stop_path, _checkpoint_path,
                   save_checkpoint, load_checkpoint, delete_checkpoint, _phase_should_skip,
                   validate_checkpoint, acquire_lock, _cleanup_lock, _signal_handler,
                   try_auto_merge, _supplement_pr_sections, _detect_default_branch,
                   _set_gh_token, show_help, show_help_json, check_upgrade, _version_newer,
                   do_release,
                   _parse_status_md, _make_status_entry, update_status_md,
                   _check_pid, _verify_pid_owner, _get_lock_state,
                   handle_status, handle_stop, handle_kill, handle_list_crons,
                   extract_file_paths, _hash_output, _detect_truncation,
                   _extract_code_context, generate_codebase_map, _describe_file,
                   _extract_tl_verdict, _extract_tl_blockers,
                   halt_and_revert, archive_specs_for_feature,
                   ensure_profiles, deploy_profile_skills)
from agent import (call_agent, spawn_agent, _run_agent,
                   _detect_provider_failure, _load_fallback_config)
from tasks import (Task, TaskDAG, TaskLock, WorktreeManager, RoadmapFeature,
                   spawn_coder_in_worktree, merge_worktree_branches,
                   run_parallel_coders, _reap_completed, _poll_until_wave_done)
from roadmap import (parse_roadmap, pick_next_feature, update_roadmap_status,
                     commit_roadmap_update, auto_repair_status,
                     run_add_to_roadmap, run_next_setup, run_init)
from pipeline import (run_pipeline, run_phase1_strategist, run_phase2_coder,
                      run_phase3_vet, run_phase4_nm, run_phase5_tech_lead,
                      run_fix_mode, run_post_pipeline,
                      discover_blocked_pr, extract_blockers_from_pr,
                      _verify_pr_impact_alignment)



# Set restrictive umask before any file writes — ensures all /tmp artifacts
# are created with owner-only permissions (0o077) by default
os.umask(0o077)

REAL_HOME = pwd.getpwuid(os.getuid()).pw_dir
HERMES = os.path.join(REAL_HOME, ".hermes")
HERMES_BIN = os.path.join(HERMES, "hermes-agent/venv/bin/hermes")
PROFILES = os.path.join(HERMES, "profiles")
PANEL_PORT = {"strategist": 8647, "tech-lead": 8644, "coder": 8645, "nm": 8648}
OUTPUT_LOG = f"/tmp/dokima-output-{datetime.datetime.now().strftime('%Y%m%d-%H%M%S')}.txt"
DEFAULT_BRANCH = "master"  # detected at startup, may be 'main'
SKIP_AUTOFIX = False       # set from --skip-autofix flag or PANEL_SKIP_AUTOFIX env
FORCE_FULL = False         # set from --force-full flag or PANEL_FORCE_FULL env
SKIP_HUMAN_GATE = False    # set from --skip-human-gate flag or PANEL_SKIP_HUMAN_GATE env
max_parallel_override = None  # set from --max-parallel=N flag in main()
FALLBACK_MODELS = {}           # populated from PANEL_FALLBACK_* env vars in main()
RESUME = None                  # set from --resume/--no-resume flag or PANEL_RESUME env
MAX_CONTINUOUS = 20            # max iterations for --continuous mode

# Read VERSION file from script directory (single source of truth)
_script_dir = os.path.dirname(os.path.abspath(__file__))
_version_path = os.path.join(_script_dir, "VERSION")
try:
    VERSION = open(_version_path).read().strip()
except OSError:
    VERSION = "unknown"

from utils import HELP_TEXT

def main():
    global API_KEY, PROJECT_DIR, REPO, TEST_CMD, BUILD_CMD, LINT_CMD, PANEL_FEATURE, DEFAULT_BRANCH, lock_fd, SKIP_AUTOFIX, FORCE_FULL, SKIP_HUMAN_GATE, max_parallel_override, FALLBACK_MODELS, RESUME
    import argparse, shutil

    # ── Pre-check: top-level flags that don't require a subcommand ──
    # These must be handled BEFORE argparse because subparsers.required=True
    # demands a subcommand. We pre-scan for these and dispatch early.
    is_help = False
    is_help_json = False
    is_map = False
    map_full = False
    flat_argv = set(sys.argv[1:])
    if '--help-json' in flat_argv:
        is_help_json = True
    if '-h' in flat_argv or '--help' in flat_argv:
        is_help = True
    if '--map' in flat_argv:
        is_map = True
    if '--map-full' in flat_argv:
        is_map = True
        map_full = True

    # ── argparse subparser setup (for subcommands only) ──
    parser = argparse.ArgumentParser(prog='dokima', add_help=False)
    # We still register these so argparse doesn't choke, but they're
    # pre-handled above so their values are ignored.
    parser.add_argument('-h', '--help', action='store_true', dest='_show_help')
    parser.add_argument('--help-json', action='store_true', dest='_show_help_json')
    parser.add_argument('--map', action='store_true', dest='_show_map')
    parser.add_argument('--map-full', action='store_true', dest='_show_map_full')

    subparsers = parser.add_subparsers(dest='command')
    subparsers.required = False  # Allow --help/--help-json without subcommand

    # ── add ──
    add_p = subparsers.add_parser('add', add_help=False)
    add_p.add_argument('feature_text', nargs='?', default='')
    add_p.add_argument('--priority', choices=['P0', 'P1', 'P2', 'P3'], default=None)
    add_p.add_argument('project_dir', nargs='?')

    # ── next ──
    next_p = subparsers.add_parser('next', add_help=False)
    next_p.add_argument('--continuous', action='store_true')
    next_p.add_argument('--interactive', action='store_true')
    next_p.add_argument('--force-full', action='store_true')
    next_p.add_argument('--skip-autofix', action='store_true')
    next_p.add_argument('--skip-auto-archive', action='store_true')
    next_p.add_argument('--skip-human-gate', action='store_true')
    next_p.add_argument('--resume', action='store_true', dest='resume_flag')
    next_p.add_argument('--no-resume', action='store_true', dest='no_resume_flag')
    next_p.add_argument('--max-parallel', type=int, default=None)
    next_p.add_argument('--base-branch', default=None, dest='base_branch_override')
    next_p.add_argument('--answers', default=None, dest='answers_path')
    next_p.add_argument('feature_hint', nargs='?')
    next_p.add_argument('project_dir', nargs='?')

    # ── fix ──
    fix_p = subparsers.add_parser('fix', add_help=False)
    fix_p.add_argument('--fix-all', action='store_true')
    fix_p.add_argument('--skip-human-gate', action='store_true')
    fix_p.add_argument('project_dir', nargs='?')

    # ── status / stop / kill ──
    for cmd in ('status', 'stop', 'kill'):
        p = subparsers.add_parser(cmd, add_help=False)
        p.add_argument('project_dir', nargs='?')

    # ── list-crons / version / upgrade ──
    for cmd in ('list-crons', 'version', 'upgrade'):
        p = subparsers.add_parser(cmd, add_help=False)
        p.add_argument('-h', '--help', action='store_true', dest=f'_{cmd}_help')
        p.add_argument('extra', nargs='*', help='Ignored extra arguments')

    # ── release ──
    rel_p = subparsers.add_parser('release', add_help=False)
    rel_p.add_argument('bump', nargs='?', choices=['patch', 'minor', 'major'])
    rel_p.add_argument('--dry-run', action='store_true')
    rel_p.add_argument('project_dir', nargs='?')

    # ── If argparse rejected the first arg (not a subcommand), fall back
    # to default pipeline where all args are positional. ──
    # We detect this: argparse exits 2 for parse errors. But we pre-scanned
    # for --help/--help-json already, so any SystemExit(2) here means the
    # first arg isn't a valid subcommand → treat as default pipeline.
    # However, parse_args() already raised SystemExit if it failed, so we
    # wrap it.
    try:
        args = parser.parse_args()
    except SystemExit as e:
        if e.code == 2:
            # Default pipeline: all args after script name are positional
            # Rebuild filtered_argv from sys.argv (skip script name)
            filtered_argv = sys.argv[1:]
            # Clear subcommand flags — this is a default pipeline run
            command = None
            is_next = False; is_continuous = False; is_fix = False
            is_add = False; is_stop = False; is_kill = False
            is_status = False; is_list_crons = False; is_version = False
            is_upgrade = False; is_release = False; is_dry_run = False
            release_bump = None; add_priority = None
            fix_all = False; skip_autofix = False; force_full = False
            skip_auto_archive = False; skip_human_gate = False
            answers_path = None; user_answers_prefill = None
            base_branch_override = os.environ.get("PANEL_BASE_BRANCH") or None
            feature = ""
            # Jump past argparse mapping to the feature/PROJECT_DIR logic
            pass
        else:
            raise
    else:
        # ── Map argparse namespace to existing state variables ──
        # Note: is_help, is_help_json, is_map, map_full are pre-set above
        command = args.command

        is_next = (command == 'next')
        is_continuous = is_next and args.continuous
        is_interactive = is_next and args.interactive
        is_fix = (command == 'fix')
        is_add = (command == 'add')
        is_stop = (command == 'stop')
        is_kill = (command == 'kill')
        is_status = (command == 'status')
        is_list_crons = (command == 'list-crons')
        is_version = (command == 'version')
        is_upgrade = (command == 'upgrade')
        is_release = (command == 'release')
        is_dry_run = False
        release_bump = None

        if is_release:
            release_bump = args.bump
            is_dry_run = args.dry_run

        add_priority = getattr(args, 'priority', None) if is_add else None

        fix_all = is_fix and getattr(args, 'fix_all', False)
        skip_autofix = False
        force_full = False
        skip_auto_archive = False
        skip_human_gate = False
        base_branch_override = os.environ.get("PANEL_BASE_BRANCH") or None
        answers_path = None
        user_answers_prefill = None

        if is_next:
            skip_autofix = args.skip_autofix
            force_full = args.force_full
            skip_auto_archive = args.skip_auto_archive
            skip_human_gate = args.skip_human_gate
            if args.resume_flag:
                RESUME = True
            elif args.no_resume_flag:
                RESUME = False
            max_parallel_override = args.max_parallel
            if args.base_branch_override:
                base_branch_override = args.base_branch_override
            answers_path = args.answers_path
            filtered_argv = [x for x in (args.feature_hint, args.project_dir) if x is not None]
        elif is_fix:
            skip_human_gate = args.skip_human_gate
            filtered_argv = [args.project_dir] if args.project_dir else []
        elif is_add:
            filtered_argv = [args.feature_text] if args.feature_text else []
            if args.project_dir:
                filtered_argv.append(args.project_dir)
        elif command in ('status', 'stop', 'kill'):
            filtered_argv = [args.project_dir] if args.project_dir else []
        elif is_release:
            filtered_argv = [args.project_dir] if args.project_dir else []
        else:
            # Default pipeline or no subcommand — use catch-all positional
            filtered_argv = list(args.positional) if hasattr(args, 'positional') else []

        feature = ""


    # ── Env var fallbacks for flags (flag wins if set, then env var, then default) ──
    if not fix_all and os.environ.get("PANEL_FIX_ALL") == "1":
        fix_all = True
    if not skip_autofix and os.environ.get("PANEL_SKIP_AUTOFIX") == "1":
        skip_autofix = True
        SKIP_AUTOFIX = True
    if not force_full and os.environ.get("PANEL_FORCE_FULL") == "1":
        force_full = True
        FORCE_FULL = True
    if not skip_auto_archive and os.environ.get("PANEL_SKIP_AUTO_ARCHIVE") == "1":
        skip_auto_archive = True
    if not skip_human_gate and os.environ.get("PANEL_SKIP_HUMAN_GATE") == "1":
        skip_human_gate = True
        SKIP_HUMAN_GATE = True
    if max_parallel_override is None:
        mp = os.environ.get("PANEL_MAX_PARALLEL")
        if mp and mp.isdigit():
            max_parallel_override = int(mp)
    # Env var fallbacks for resume/no-resume (only if flag not explicitly set)
    if RESUME is None:
        if os.environ.get("PANEL_RESUME") == "1":
            RESUME = True
        elif os.environ.get("PANEL_NO_RESUME") == "1":
            RESUME = False


    # ── If answers_path was set via argparse (next subcommand), load the file ──
    if answers_path and not user_answers_prefill:
        try:
            with open(answers_path) as f:
                interview_state = json.load(f)
            answers_list = interview_state.get("answers", [])
            questions = interview_state.get("questions", [])
            if answers_list and questions:
                user_answers_prefill = "\n".join(
                    f"Clarification: {q}\nUser's answer: {a}"
                    for q, a in zip(questions, answers_list)
                )
                print(f"  ✓ Loaded {len(answers_list)} answer(s) from {answers_path}", flush=True)
        except (FileNotFoundError, json.JSONDecodeError, IOError) as e:
            print(f"  ⚠ Failed to load answers file '{answers_path}': {e}", flush=True)
            answers_path = None

    # ── Determine PROJECT_DIR and feature ──
    if is_next or is_stop or is_kill or is_status or is_fix or is_map:
        if is_stop or is_kill or is_status or is_map:
            if len(filtered_argv) >= 1:
                PROJECT_DIR = os.path.abspath(filtered_argv[0])
            else:
                PROJECT_DIR = os.getcwd()
        elif is_fix:
            if len(filtered_argv) >= 1:
                PROJECT_DIR = os.path.abspath(filtered_argv[0])
            else:
                PROJECT_DIR = os.getcwd()
            PANEL_FEATURE = f"fix: {PROJECT_DIR}"
        else:
            # --next: if two+ args, first is feature, second is project dir
            # If one arg, it's the project dir (feature comes from roadmap)
            if len(filtered_argv) >= 2:
                PROJECT_DIR = os.path.abspath(filtered_argv[1])
                feature = filtered_argv[0]
            else:
                PROJECT_DIR = os.path.abspath(filtered_argv[0]) if filtered_argv else os.getcwd()
            PANEL_FEATURE = feature
    else:
        if len(filtered_argv) < 1 and not is_help and not is_help_json and not is_list_crons and not is_version and not is_upgrade and not is_release:
            print("ERROR: Feature description required")
            sys.exit(1)
        feature = filtered_argv[0] if filtered_argv else ""
        PANEL_FEATURE = feature
        # init uses different argv layout: "init" <description> [project_dir]
        if feature == "init":
            PROJECT_DIR = os.path.abspath(filtered_argv[2]) if len(filtered_argv) >= 3 else os.getcwd()
        else:
            PROJECT_DIR = os.path.abspath(filtered_argv[1]) if len(filtered_argv) >= 2 else os.getcwd()

    # ── CONTROL FLAGS: early exit (priority order) ──
    if is_upgrade:
        check_upgrade()
    if is_version:
        print(f"dokima v{VERSION}")
        sys.exit(0)
    if is_help_json:
        show_help_json()
    if is_help:
        show_help()
    if is_kill:
        handle_kill(PROJECT_DIR)
    if is_add:
        add_feature = " ".join(filtered_argv) if filtered_argv else ""
        if not add_feature:
            print("ERROR: --add requires a feature description.")
            print("Usage: dokima --add 'Feature description' [--priority=P0] [dir]")
            sys.exit(1)
        run_add_to_roadmap(add_feature, PROJECT_DIR, priority_hint=add_priority)
        print("\n  Roadmap updated. Run 'dokima --next' to build the next feature.")
        sys.exit(0)
    if is_stop:
        handle_stop(PROJECT_DIR)
    if is_status:
        handle_status(PROJECT_DIR)
    if is_list_crons:
        handle_list_crons()
    if is_release:
        if release_bump is None:
            print("ERROR: --release requires a bump type (patch, minor, or major)", flush=True)
            print("Usage: dokima --release <patch|minor|major> [--dry-run] [project_dir]", flush=True)
            sys.exit(1)
        do_release(release_bump, os.getcwd() if is_release and len(filtered_argv) == 0 else PROJECT_DIR, dry_run=is_dry_run)
        return
    if is_map:
        generate_codebase_map(PROJECT_DIR, full=map_full)
        return

    # ── INIT MODE: discovery & constitution, no pipeline ──
    if not is_next and feature == "init":
        # init <description> [project_dir]
        init_desc = filtered_argv[1] if len(filtered_argv) >= 2 else ""
        init_project_dir = os.path.abspath(filtered_argv[2]) if len(filtered_argv) >= 3 else PROJECT_DIR
        run_init(init_desc, init_project_dir)
        return

    # ── LOCK ACQUISITION ──
    _, lock_fd = acquire_lock()
    global _LOCK_FD
    _LOCK_FD = lock_fd
    signal.signal(signal.SIGINT, _signal_handler)
    signal.signal(signal.SIGTERM, _signal_handler)
    import atexit
    atexit.register(_cleanup_lock)
    # ── PROJECT SETUP ──
    # Validate PROJECT_DIR is a real git repo before proceeding
    if not _validate_project_dir(PROJECT_DIR):
        print(f"ERROR: {PROJECT_DIR} is not a valid git repository (no .git directory found).")
        print("  The panel requires a git repository to operate in.")
        print("  Use a project directory that has been initialized with 'git init' or cloned from GitHub.")
        _cleanup_lock()
        sys.exit(1)

    agents_path = os.path.join(PROJECT_DIR, "AGENTS.md")
    if not os.path.exists(agents_path):
        print(f"ERROR: No AGENTS.md found in {PROJECT_DIR}")
        print("  The panel requires an AGENTS.md at the project root with at minimum:")
        print("  project description, test command, build command, and conventions.")
        print("  See ai-coding-best-practices for AGENTS.md guidelines.")
        _cleanup_lock()
        sys.exit(1)

    API_KEY = load_key()
    if not API_KEY:
        print("ERROR: Could not read API_SERVER_KEY from .env")
        _cleanup_lock()
        sys.exit(1)

    # ── Load fallback model config ──
    FALLBACK_MODELS = _load_fallback_config()
    if FALLBACK_MODELS:
        roles = ", ".join(FALLBACK_MODELS.keys())
        print(f"  ✓ Fallback models configured for: {roles}", flush=True)

    REPO = detect_repo()
    if not REPO:
        print("ERROR: Could not detect GitHub owner/repo from git remote origin.")
        print("  The panel needs a GitHub remote to create PRs and issues.")
        _cleanup_lock()
        sys.exit(1)

    DEFAULT_BRANCH = _detect_default_branch(PROJECT_DIR)
    if base_branch_override:
        DEFAULT_BRANCH = base_branch_override
        print(f"  ⚡ Base branch override: {DEFAULT_BRANCH}", flush=True)
    _set_gh_token()
    TEST_CMD, BUILD_CMD, LINT_CMD = detect_commands()

    # ── --answers interaction for --fix ──
    if is_fix and answers_path is not None:
        print("  ⚠ --fix mode ignores --answers (no strategist interview). Continuing...", flush=True)

    # ── FIX MODE: early dispatch ──
    if is_fix:
        # Use _pipeline reference so test patches on pipeline module take effect
        _pipeline.run_fix_mode(project_dir=PROJECT_DIR, fix_all=fix_all, skip_human_gate=skip_human_gate)
        _cleanup_lock()
        return

    # ── Auto-archive specs from merged PRs (fallback startup scan) ──
    specs_dir = os.path.join(PROJECT_DIR, "specs")
    archive_dir = os.path.join(specs_dir, "archive")
    if os.path.isdir(specs_dir) and not skip_auto_archive:
        merged_archived = 0
        for entry in sorted(os.listdir(specs_dir)):
            entry_path = os.path.join(specs_dir, entry)
            if not os.path.isdir(entry_path) or entry == "archive":
                continue
            # Use case-insensitive branch matching: lowercased entry matches slugify'd branch
            branch_name = f"feat/{entry.lower()}"[:80]
            try:
                result = subprocess.run(
                    ["gh", "pr", "list", "--repo", REPO, "--head", branch_name,
                     "--state", "merged", "--json", "number", "--jq", ".[0].number"],
                    capture_output=True, text=True, timeout=15)
                if result.returncode == 0 and result.stdout.strip():
                    os.makedirs(archive_dir, exist_ok=True)
                    archive_path = os.path.join(archive_dir, entry)
                    if os.path.exists(archive_path):
                        shutil.rmtree(archive_path)
                    shutil.move(entry_path, archive_path)
                    merged_archived += 1
            except Exception:
                pass
        if merged_archived:
            print(f"  Auto-archive: {merged_archived} merged spec(s) → specs/archive/")

    # ── NEXT MODE: pick feature from roadmap ──
    if is_next:
        git("checkout", DEFAULT_BRANCH)
        git("pull", "origin", DEFAULT_BRANCH)
        feature_hint = filtered_argv[0] if len(filtered_argv) >= 2 else None
        feature = run_next_setup(interactive=is_interactive, feature_hint=feature_hint)
        if feature is None:
            print("Nothing to do.")
            _cleanup_lock()
            return
        PANEL_FEATURE = feature

    # ── Pre-pipeline stop file check ──
    sp = _stop_path(PROJECT_DIR)
    if os.path.exists(sp):
        print("  ⚠ Stop file detected — halting before pipeline")
        os.remove(sp)
        _cleanup_lock()
        return

    # ── Sync module globals before pipeline execution (F022b) ──
    _sync_modules()

    # ── RUN PIPELINE ──
    if is_continuous:
        roadmap_path = os.path.join(PROJECT_DIR, "specs", "roadmap.md")
        for iteration in range(1, MAX_CONTINUOUS + 1):
            print(f"\n{'═'*60}")
            print(f"  CONTINUOUS — Feature {iteration}")
            print(f"{'═'*60}\n")

            run_pipeline(feature, is_next, True, user_answers_prefill, resume=RESUME)

            # Check stop file
            if os.path.exists(_stop_path()):
                print("\n  ⚠ Stop file detected — halting continuous loop")
                os.remove(_stop_path())
                break

            if iteration >= MAX_CONTINUOUS:
                print(f"\n── Continuous: max iterations ({MAX_CONTINUOUS}) reached")
                break

            # Pick next feature
            if not os.path.exists(roadmap_path):
                break
            features = parse_roadmap(roadmap_path)
            auto_repair_status(features, roadmap_path)
            features = parse_roadmap(roadmap_path)
            next_feat = pick_next_feature(features)
            if not next_feat:
                print("\n── Continuous: all features complete")
                break
            feature = f"{next_feat.id}: {next_feat.title}"
            PANEL_FEATURE = feature
            update_roadmap_status(roadmap_path, next_feat.id, "in_progress")
            commit_roadmap_update(roadmap_path, next_feat.id, "start")
            status_path_c = os.path.join(PROJECT_DIR, "specs", "STATUS.md")
            branch_c = f"feat/{slugify(feature)[:50]}"
            update_status_md(status_path_c, next_feat.id, next_feat.title, "in_progress", branch=branch_c, source="panel")
            print(f"\n  Next: {next_feat.id} — {next_feat.title}")
    else:
        run_pipeline(feature, is_next, False, user_answers_prefill, resume=RESUME)

    _sync_modules()
    _cleanup_lock()

def _sync_modules():
    """Propagate mutable globals to all module files (F022)."""
    try:
        for g in ('PROJECT_DIR', 'REPO', 'DEFAULT_BRANCH', 'PANEL_FEATURE',
                  'PANEL_DIR', 'API_KEY', 'OUTPUT_LOG', 'HERMES_BIN',
                  'FALLBACK_MODELS', 'SKIP_AUTOFIX', 'FORCE_FULL',
                  'SKIP_HUMAN_GATE', 'max_parallel_override', 'RESUME',
                  'TEST_CMD', 'BUILD_CMD', 'LINT_CMD'):
            val = globals().get(g)
            if val is not None:
                for mod in (_utils, _agent, _tasks, _roadmap, _pipeline):
                    if hasattr(mod, g):
                        setattr(mod, g, val)
    except Exception:
        pass

if __name__ == "__main__":
    main()
